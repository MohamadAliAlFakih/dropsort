# ============================================================
# dropsort — Bootstrap environment variables
# ============================================================
# Copy to .env and fill in values: cp .env.example .env
#
# Published ports and the Vault dev root token live here. Application secrets
# (DB password, JWT signing key, etc.) are intended to resolve from Vault at
# runtime in later phases — see SECURITY.md / RUNBOOK.md.
#
# VITE_API_BASE_URL is not a server secret: it is a public API origin string
# passed into the frontend image at Docker build time (Vite inlines it).
# ============================================================

# --- Vault dev mode ---
# Root token for dev-mode Vault. Wiped + re-seeded on every `docker compose down -v`.
VAULT_DEV_ROOT_TOKEN=dropsort-dev-token

# --- Service ports (host-side bindings only) ---
API_PORT=8000
FRONTEND_PORT=5173

# Browser-reachable FastAPI origin for the SPA bundle (Docker build-arg for `frontend`).
VITE_API_BASE_URL=http://127.0.0.1:8000

POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
SFTP_PORT=2222
VAULT_PORT=8200
