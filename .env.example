# ============================================================
# dropsort — Bootstrap environment variables
# ============================================================
# Copy to .env and fill in values: cp .env.example .env
#
# Per INFRA-02 (project brief) and CONTEXT D-14:
# This file contains ONLY the Vault root token and ports.
# All other secrets (DB password, Redis auth, MinIO creds, SFTP creds, JWT
# signing key) resolve from Vault at startup via `app/core/vault.py` (Phase 3).
# ============================================================

# --- Vault dev mode ---
# Root token for dev-mode Vault. Wiped + re-seeded on every `docker compose down -v`.
VAULT_DEV_ROOT_TOKEN=dropsort-dev-token

# --- Service ports (host-side bindings only) ---
API_PORT=8000
FRONTEND_PORT=5173
# Frontend SPA API origin used during Docker build
VITE_API_BASE_URL=http://127.0.0.1:8000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
SFTP_PORT=2222
VAULT_PORT=8200
