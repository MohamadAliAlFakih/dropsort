# ============================================================
# dropsort — Bootstrap environment variables
# ============================================================
# Copy to .env and fill in values: cp .env.example .env
#
# Published ports and the Vault dev root token live here. Server secrets for the
# Python services are loaded from Vault at runtime (see `scripts/vault-seed.sh` and ARCH.md).
#
# VITE_API_BASE_URL is not a server secret: it is a public API origin string
# passed into the frontend image at Docker build time (Vite inlines it).
# ============================================================

# --- Initial admin (must match Vault seed; used for first login after compose up) ---
ADMIN_INITIAL_PASSWORD=dropsort-admin-dev

# Optional: override JWT signing key written by scripts/vault-seed.sh (dev default otherwise)
# JWT_SIGNING_KEY=

# Root token for dev-mode Vault. Wiped + re-seeded on every `docker compose down -v`.
VAULT_DEV_ROOT_TOKEN=dropsort-dev-token

# --- Service ports (host-side bindings only) ---
API_PORT=8000
FRONTEND_PORT=5173

# Browser-reachable FastAPI origin for the SPA bundle (Docker build-arg for `frontend`).
VITE_API_BASE_URL=http://127.0.0.1:8000

POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
SFTP_PORT=2222
VAULT_PORT=8200
